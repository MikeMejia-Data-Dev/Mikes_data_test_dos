# Copiar este archivo a .env y completar con valores reales antes de levantar el entorno.
# El archivo .env real NUNCA debe subirse al repositorio (ver .gitignore).

# --- Airflow metadata DB ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me_airflow
AIRFLOW_DB_NAME=airflow_meta

# --- Airflow admin user (UI en http://localhost:8080) ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin

# --- Fernet key para encriptar Connections de Airflow ---
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_key

# --- Repositorio analítico (Data Warehouse) ---
DW_DB_USER=datamart
DW_DB_PASSWORD=change_me_dw
DW_DB_NAME=datamart_dw